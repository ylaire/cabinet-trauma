---
import { Image } from 'astro:assets';
import logo from '../assets/logo-traumato-auray.png';
import entorse from '../assets/pathologies/entorse.jpg';
import contusion from '../assets/pathologies/contusion.jpg';
import fracture from '../assets/pathologies/fracture.jpg';
import musculaire from '../assets/pathologies/musculaire.jpg';
import luxation from '../assets/pathologies/luxation.jpg';
import plaie from '../assets/pathologies/plaie.jpg';

const medecinsAssocies = [
  {
    initiales: "RB",
    nom: "Dr Romain Bousquet",
    role: "Médecin associé",
    formations: [
      "Spécialiste en médecine générale",
      "DIU Urgences Traumatologiques",
      "Capacité d'Aide Médicale Urgente (CAMU)",
      "Capacité de médecine et traumatologie du sport",
    ]
  },
  {
    initiales: "CG",
    nom: "Dr Christophe Guillaud-Vallée",
    role: "Médecin associé",
    formations: [
      "Spécialiste en médecine générale",
      "DIU Urgences Traumatologiques",
      "Capacité d'Aide Médicale Urgente (CAMU)",
      "Capacité de médecine et traumatologie du sport",
    ]
  },
  {
    initiales: "JR",
    nom: "Dr Julien Robin",
    role: "Médecin associé",
    formations: [
      "Spécialiste en médecine générale",
      "DIU Urgences Traumatologiques",
    ]
  },
];

const medecinsCollaborateurs = [
  {
    initiales: "CD",
    nom: "Dr Camille Deschamps",
    role: "Médecin collaborateur",
    formations: [
      "Spécialiste en médecine générale",
      "DIU Urgences Traumatologiques",
    ]
  },
  {
    initiales: "AD",
    nom: "Dr Augustin Dupouet",
    role: "Médecin collaborateur",
    formations: [
      "Spécialiste en médecine générale",
      "DIU Urgences Traumatologiques",
    ]
  },
  {
    initiales: "BL",
    nom: "Dr Baptiste Laudrin",
    role: "Médecin collaborateur",
    formations: [
      "Spécialiste en médecine générale",
      "DIU Urgences Traumatologiques",
      "Capacité de médecine et traumatologie du sport",
    ]
  },
  {
    initiales: "FM",
    nom: "Dr Florent Maillard",
    role: "Médecin collaborateur",
    formations: [
      "Spécialiste en médecine générale",
      "DESC Médecine d'urgence",
      "Capacité de médecine et traumatologie du sport",
    ]
  },
